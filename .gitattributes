# Normalize line endings to LF in the repository for all text files.
* text=auto eol=lf

# Scripts (enforce explicit line endings)
*.sh        text eol=lf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary files (never normalize)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
